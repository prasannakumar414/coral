              "type": [
                "boolean",
                "null"
              ]
            },
            "hint": {
              "type": [
                "string",
                "null"
              ]
            },
            "credential": true,
            "kind": {
              "type": "string",
              "const": "secret"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        }
      ]
    },
    "AuthSpec": {
      "description": "Source-level authentication requirements for HTTP-backed source specs.",
      "oneOf": [
        {
          "description": "HTTP Basic authentication; runtime base64-encodes `username:password`.",
          "type": "object",
          "properties": {
            "username": {
              "$ref": "#/$defs/ParsedTemplate"
            },
            "password": {
              "$ref": "#/$defs/ParsedTemplate"
            },
            "type": {
