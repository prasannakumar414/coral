              "const": "BasicAuth"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "username",
            "password"
          ]
        },
        {
          "description": "Declarative list of auth headers to attach to the request.",
          "type": "object",
          "properties": {
            "headers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/HeaderSpec"
              },
              "default": []
            },
            "type": {
              "type": "string",
              "const": "HeaderAuth"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "description": "Dispatches auth header resolution to a runtime-registered authenticator.",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "CustomAuth"
            }
          },
          "$ref": "#/$defs/CustomAuthSpec",
          "required": [
            "type"
          ]
        }
      ]
    },
